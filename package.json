{
  "name": "fortune-shrine",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 127.0.0.1 -p 4188",
    "build": "next build",
    "next:start": "next start -H 127.0.0.1 -p 4188",
    "start": "node server.mjs",
    "legacy:start": "node server.mjs",
    "test:distribution": "node scripts/test-distribution-engine.mjs",
    "telegram:login": "node scripts/telegram-discovery/run.mjs --login-only",
    "telegram:discover": "node scripts/telegram-discovery/run.mjs --once",
    "telegram:watch": "node scripts/telegram-discovery/run.mjs --watch",
    "telegram:queue": "scripts/telegram-discovery/open-operation-queue.sh",
    "test:telegram-discovery": "node --test scripts/telegram-discovery/test.mjs scripts/telegram-discovery/test-reply-queue-v2.mjs"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "playwright": "^1.57.0",
    "tailwindcss": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
